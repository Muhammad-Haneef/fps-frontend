{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "components/NavMain.jsx", "app/(admin)/layout.jsx", "components/team-switcher.jsx", "components/nav-user.jsx", "components/nav-projects.jsx", "components/app-sidebar.jsx", "app/(admin)/dashboard/page.jsx", "components/layouts/admin/company-switcher.jsx", "ccomponents/layouts/admin/NavUser.jsx", "ccomponents/layouts/admin/NavMain.jsx", "app/(admin)/warehouses/sapre_data_table/columns.jsx", "app/(admin)/warehouses/sapre_data_table/data-table.jsx", "components/layouts/admin/app-sidebar.jsx",],
  "exclude": ["node_modules"]
}
